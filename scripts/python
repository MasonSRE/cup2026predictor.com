#!/usr/bin/env bash
set -euo pipefail
if command -v python3.11 >/dev/null 2>&1; then
  exec python3.11 "$@"
fi
if [ -x /Users/tuboshu/.hermes/hermes-agent/venv/bin/python3.11 ]; then
  exec /Users/tuboshu/.hermes/hermes-agent/venv/bin/python3.11 "$@"
fi
if command -v uv >/dev/null 2>&1; then
  exec uv run --python 3.11 python "$@"
fi
echo "Python 3.11 is required. Install python3.11 or uv." >&2
exit 1
